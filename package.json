{
  "name": "changedetection-mcp",
  "version": "0.1.0",
  "description": "MCP server for changedetection.io",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "changedetection-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/server.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));\"",
    "prepare": "tsc && node -e \"const fs=require('fs');const f='dist/server.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));\"",
    "start": "node --experimental-strip-types src/server.ts",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3"
  }
}
